# 依赖包（不需要备份，用 npm install 恢复）
node_modules/
backend/node_modules/
frontend/node_modules/

# 数据库文件（运行时自动重新生成）
backend/data/

# 上传文件
backend/uploads/

# 构建产物
frontend/dist/
frontend/.vite/

# 日志
*.log
npm-debug.log*

# 环境变量（含密码等敏感信息）
.env
.env.local
.env.production

# 系统文件
.DS_Store
Thumbs.db

# IDE配置
.vscode/settings.json
